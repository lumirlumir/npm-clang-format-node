{
  "extends": "../../tsconfig.base.json",
  "include": [
    "src/**/*.js",
    "src/**/*.mjs",
    "src/**/*.cjs",
    "src/**/*.jsx",
    "src/**/*.ts",
    "src/**/*.mts",
    "src/**/*.cts",
    "src/**/*.tsx"
  ],
  "exclude": ["src/**/*.test.js", "src/**/*.test.ts", "**/fixtures/**"],
  "compilerOptions": {
    /* Modules */
    "rootDir": "./src",

    /* Emit */
    "outDir": "build"
  }
}
